SECRET_KEY=change-this-django-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver,raydonsystems.co.zw,www.raydonsystems.co.zw,.raydonsystems.co.zw
TIME_ZONE=Africa/Harare
PORT=8005

# PostgreSQL is the production target.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/raydon_school

# Optional when serving through HTTPS/proxies.
CSRF_TRUSTED_ORIGINS=https://raydonsystems.co.zw,https://www.raydonsystems.co.zw,http://raydonsystems.co.zw,http://www.raydonsystems.co.zw
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
